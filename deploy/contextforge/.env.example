# Copy this file to .env for local evaluation and replace every placeholder.
# Never commit .env.
# Keys: openssl rand -hex 32
# Passwords: use independent values with uppercase, lowercase, and digits.

HOST=0.0.0.0
PORT=4444
DATABASE_URL=postgresql+psycopg://contextforge:replace-password@postgres.example.com:5432/contextforge

JWT_SECRET_KEY=replace-with-an-independent-random-64-character-value
AUTH_ENCRYPTION_SECRET=replace-with-an-independent-random-64-character-value
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=replace-with-a-random-admin-password
BASIC_AUTH_USER=contextforge-operator
BASIC_AUTH_PASSWORD=replace-with-an-independent-random-basic-auth-password

ENVIRONMENT=development
APP_DOMAIN=http://localhost:4444
SECURE_COOKIES=false
JWT_AUDIENCE=mcpgateway-api
JWT_ISSUER=mcpgateway
JWT_AUDIENCE_VERIFICATION=true
JWT_ISSUER_VERIFICATION=true
TOKEN_EXPIRY=60
AUTH_REQUIRED=true
MCP_CLIENT_AUTH_ENABLED=true
MCP_REQUIRE_AUTH=true
PUBLIC_REGISTRATION_ENABLED=false
REQUIRE_STRONG_SECRETS=true
REQUIRE_TOKEN_EXPIRATION=true
REQUIRE_JTI=true
API_ALLOW_BASIC_AUTH=false
DOCS_ALLOW_BASIC_AUTH=false
INSECURE_ALLOW_QUERYPARAM_AUTH=false
SKIP_SSL_VERIFY=false
SSRF_PROTECTION_ENABLED=true
SSRF_ALLOW_LOCALHOST=false
SSRF_ALLOW_PRIVATE_NETWORKS=false
SSRF_DNS_FAIL_CLOSED=true
CORS_ENABLED=false
SECURITY_HEADERS_ENABLED=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS_ENABLED=true
REMOVE_SERVER_HEADERS=true
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_REQUESTS=false
MCPGATEWAY_UI_ENABLED=true
MCPGATEWAY_ADMIN_API_ENABLED=true
